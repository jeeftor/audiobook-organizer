{
  "name": "audiobook-organizer-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "docs:cli": "node scripts/capture-docs-cli.mjs",
    "docs:cli:gifs": "node scripts/capture-docs-cli-gifs.mjs",
    "docs:site": "ASTRO_TELEMETRY_DISABLED=1 astro build && node scripts/copy-docs-generated-assets.mjs",
    "docs:starlight:build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "docs:starlight:dev": "ASTRO_TELEMETRY_DISABLED=1 node scripts/copy-docs-generated-assets.mjs && ASTRO_TELEMETRY_DISABLED=1 astro dev --host 127.0.0.1 --port 4321",
    "docs:starlight:preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview --host 127.0.0.1 --port 4322",
    "docs:screenshots": "node scripts/capture-docs-screenshots.mjs",
    "docs:tui": "node scripts/capture-docs-tui.mjs",
    "docs:verify": "node scripts/verify-starlight-docs.mjs",
    "install:browsers": "playwright install chromium",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:headed": "npm run build && playwright test --headed",
    "test:e2e:ui": "npm run build && playwright test --ui"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.2",
    "lucide-vue-next": "^0.468.0",
    "vite": "^7.2.7",
    "vue": "^3.5.26"
  },
  "devDependencies": {
    "@astrojs/starlight": "^0.39.2",
    "@playwright/test": "^1.60.0",
    "astro": "^6.3.7",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.1.8"
  }
}
