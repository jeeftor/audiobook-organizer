Output "output/docs-visuals/tui/tui-organize-preview.gif"

Require bin/audiobook-organizer

Set Shell "bash"
Set FontSize 16
Set Width 1440
Set Height 860
Set Theme "Dracula"
Set Padding 18
Set Framerate 18
Set TypingSpeed 20ms

Hide
Type "bin/audiobook-organizer tui --dir=output/docs-tui-sample/embedded/source --out=output/docs-tui-sample/embedded/organized --use-embedded-metadata"
Enter
Show

Sleep 2s
Enter
Sleep 900ms
Type "c"
Sleep 2s
